# ===========================================
# koivulabs-hub — Environment Variables
# ===========================================
# Kopioi tama tiedosto nimella .env.local
# Tayta oikeat arvot Firebase consolesta / Vercel dashboardista
#
# HUOM: .env.local EI commitoida gittiin (.gitignore kattaa .env*)
# ===========================================

# --- Firebase Client (NEXT_PUBLIC_ = nakyy selaimessa) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Firebase Admin (server-side only) ---
# JSON-muotoinen service account key, yhtenä rivinä
FIREBASE_SERVICE_ACCOUNT_KEY=

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
MY_TELEGRAM_USER_ID=

# --- OpenAI ---
OPENAI_API_KEY=

# --- GitHub Content API ---
GITHUB_TOKEN=
GITHUB_REPO_OWNER=koivulabs
GITHUB_REPO_NAME=koivulabs-hub
