rules_version = '2';

// Deny-by-default Firestore rules for koivulabs-hub.
//
// Public collections (logs, projects) are readable without auth but
// writable only by admin users (custom claim `admin == true`).
//
// All other collections (pendingPosts, userState, invoices, timeEntries,
// clients, siteContent, nowPage, invoiceSettings, contactMessages) are
// written/read ONLY via the Admin SDK on the server. Admin SDK bypasses
// these rules, so client-side access is fully denied.
//
// Admin claim is set with scripts/set-admin-claim.ts (one-time per user).

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // Dev logs — public feed (clients must query with where('status','==','Published')),
    // admin reads/writes freely via client SDK in admin panel.
    match /logs/{logId} {
      allow read: if resource.data.status == 'Published' || isAdmin();
      allow write: if isAdmin();
    }

    // Projects — public catalog, admin-only writes
    match /projects/{projectId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Everything else: server-only (Admin SDK bypasses rules)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
